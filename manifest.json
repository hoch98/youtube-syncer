{
  "manifest_version": 3,
  "name": "Watch Together",
  "version": "1.0.0",
  "icons": {
    "16": "images/ra.jpg",
    "128": "images/ra.jpg"
  },
  "background": {
    "service_worker": "sw-tips.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["storage", "tabs"],
  "minimum_chrome_version": "102",
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}